# ── App ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
# Comma-separated list of allowed origins (your Railway domain goes here)
CORS_ORIGINS=["https://your-app.up.railway.app"]

# ── Database ──────────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically when you add the Postgres plugin.
# Leave blank here — Railway sets it for you.
DATABASE_URL=

# ── Auth ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Attorney / Firm ───────────────────────────────────────────────────
ATTORNEY_PHONE=+15551234567       # E.164 format — receives urgent SMS alerts
ATTORNEY_EMAIL=attorney@yourfirm.com
FIRM_NAME=Williams Law Group

# ── Twilio (SMS alerts + phone intake) ───────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your Twilio phone number in E.164 format
TWILIO_FROM_NUMBER=+15559876543

# ── SendGrid (email alerts) ───────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=intake@yourfirm.com

# ── Stripe (billing — not yet wired up) ──────────────────────────────
# Format: sk_live_... (live) or sk_test_... (test)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ── Google Calendar (appointments — not yet wired up) ────────────────
GOOGLE_CREDENTIALS_PATH=
GOOGLE_CALENDAR_ID=primary
